 shorttitle = {Weaponized Health Communication},
 title = {Weaponized Health Communication: Twitter Bots and Russian Trolls Amplify the Vaccine Debate},
 url = {https://ajph.aphapublications.org/doi/full/10.2105/AJPH.2018.304567},
